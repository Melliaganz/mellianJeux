# NODE_ENV selectionne le fichier charge : .env.development (defaut) ou .env.production.
# .env sert de fallback si .env.<NODE_ENV> est absent.
# Copier ce fichier en .env.development et .env.production puis adapter DATABASE_URL.
PORT=2567
# Bases dev et prod separees (docker-compose cree mellianjeux_dev et mellianjeux_prod).
DATABASE_URL=postgresql://mellian:change-me@localhost:5433/mellianjeux_dev
